# Copy this file to .env and fill in the secrets.

# Publishing method
# email = WordPress.com Post by Email. Best no-fee route for WordPress.com blogs.
# rest = WordPress REST API. Best for self-hosted/plugin-enabled sites.
WP_POST_METHOD=email

# WordPress REST connection, used only when WP_POST_METHOD=rest.
WP_BASE_URL=https://your-site.example
WP_USERNAME=automation-author
WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress.com Post by Email, used only when WP_POST_METHOD=email.
POST_BY_EMAIL_ADDRESS=your-secret-address@post.wordpress.com
POST_BY_EMAIL_PUBLICIZE=

# You asked for live publishing. Use draft while testing if you want a safety pass.
POST_STATUS=publish

# Required only if POST_STATUS=publish. This prevents accidental live publishing.
AUTO_PUBLISH_CONFIRM=I_UNDERSTAND_POSTS_GO_LIVE

# Sender email account. Create a dedicated free email account if possible.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true
# Outlook.com example: SMTP_HOST=smtp-mail.outlook.com, SMTP_PORT=587, SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Article generation
# free = no paid AI API. Creates original news-style articles.
# openai = higher-polish generated article. Requires OPENAI_API_KEY and may cost money.
ARTICLE_GENERATOR=free
HERO_IMAGE_MODE=real
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Run controls
MAX_POSTS_PER_RUN=1
MAX_POSTS_PER_DAY=24
LOOKBACK_HOURS=96
MIN_SOURCES_PER_POST=2
REQUEST_TIMEOUT_SECONDS=25
RUN_LOCK_STALE_SECONDS=1800
TOPIC_FOCUS_KEYWORDS=science,scientists,research,researchers,breakthrough,discovery,experiment,study,physics,biology,chemistry,climate,energy,robotics,space,nasa,astronomy,planet,moon,mars,telescope,galaxy,phone,phones,iphone,ios,android,apple,samsung,pixel,gadget,gadgets,ai,artificial intelligence,software,apps,app,innovation,health,medical,medicine,doctor,hospital,patient,treatment,disease,virus,vaccine,clinical,drug,pharmaceutical,nutrition,fitness,mental health,wellness
CATEGORY_ROTATION=science,space,ai,gadgets,phones,android,apple,software,security,tutorials,hacks,health
CATEGORY_WEIGHTS=science=6,space=6,ai=6,gadgets=6,security=6,tutorials=6,hacks=6,phones=6,apple=6,android=6,software=6,health=6,tech=4
RECENT_CATEGORY_WINDOW=8
RECENT_CATEGORY_PENALTY=4
ALLOW_SINGLE_SOURCE_PRIORITY_POSTS=true
SINGLE_SOURCE_PRIORITY_CATEGORIES=science,space
SINGLE_SOURCE_MIN_QUALITY=4

# Optional taxonomy behavior. When true, the script tries to create missing terms.
WP_CREATE_TERMS=false

# Optional: comma-separated domains to skip even if they appear in config.
BLOCKLIST_DOMAINS=

# X/Twitter sharing
# Create an X Developer App, then run src/x_oauth_setup.py to fill the token values.
# Do not paste tokens into chat.
BLOG_FEED_URL=https://chuckyscarnage.tech.blog/feed/
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/callback
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access
X_USER_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_TOKEN_EXPIRES_AT=
X_SHARE_MAX_PER_RUN=2
X_SHARE_BACKFILL=false
X_SHARE_TEMPLATE=New on Chucky's Carnage: {title}\n{link}
X_SHARE_STATE_PATH=data/x_shared_posts.json
